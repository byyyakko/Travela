# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.lovable.app

# Supabase Auth project used to verify frontend JWTs.
# Prefer the anon/publishable key here. The server can fall back to service keys
# when only legacy backend env vars are configured.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# New Supabase project — service role key (never expose publicly)
SUPABASE_OWN_URL=https://your-project-ref.supabase.co
SUPABASE_OWN_SERVICE_KEY=your-service-role-key-here
